{
  "name": "turnlog",
  "version": "0.2.4",
  "description": "Search and replay every Claude Code session you've ever run — locally.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://turnlog.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/turnlog/turnlog.git"
  },
  "bugs": {
    "url": "https://github.com/turnlog/turnlog/issues"
  },
  "keywords": [
    "claude-code",
    "search",
    "replay",
    "sessions",
    "local",
    "cli",
    "jsonl",
    "fts5"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "turnlog": "bin/turnlog.cjs"
  },
  "files": [
    "bin",
    "dist",
    "web/dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "workspaces": [
    "web"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build -w web",
    "build:server": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && npm run typecheck -w web",
    "dev": "node scripts/dev.mjs",
    "dev:web": "npm run dev -w web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "golden:update": "UPDATE_GOLDEN=1 vitest run test/adapter.test.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
